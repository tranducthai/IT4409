VITE_API_BASE_URL=http://127.0.0.1:8000/api
VITE_USE_MOCK_DATA=false
VITE_MOCK_SESSION_ROLE=STUDENT

# WebRTC TURN server – cần thiết khi deploy trên internet (2 máy khác ISP/NAT)
# Đăng ký miễn phí tại https://www.metered.ca/tools/openrelay/ rồi điền vào đây
# Hoặc dùng open relay bên dưới để test nhanh (rate-limited):
VITE_TURN_URLS=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443,turn:openrelay.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=openrelayproject
VITE_TURN_CREDENTIAL=openrelayproject
