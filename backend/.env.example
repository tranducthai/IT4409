# Server
PORT=3000
# Bind host (Windows may block 0.0.0.0 on some ports)
HOST=127.0.0.1

# If you see EACCES on port 3000, try another port (e.g. 3001 or 4000)
# PORT=3001

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=online_learning

# Postgres (Neon)
# If DATABASE_URL is set, the app will use Postgres instead of MySQL.
# Neon requires SSL; keep PG_SSL=true.
DATABASE_URL=
PG_SSL=true

# JWT
# Example formats: 900, 900s, 15m, 7d
JWT_SECRET=change_me
JWT_EXPIRES_IN=15m
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=app_password
SMTP_FROM=your@gmail.com
APP_BASE_URL=http://localhost:3000