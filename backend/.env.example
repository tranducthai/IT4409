# Server
PORT=8000
# Bind host (Windows may block 0.0.0.0 on some ports)
HOST=127.0.0.1
# Render production can omit HOST; the app binds 0.0.0.0 when NODE_ENV=production.
# CORS accepts comma-separated origins.
CORS_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=online_learning

# Postgres (Neon)
# If DATABASE_URL is set, the app will use Postgres instead of MySQL.
# Neon requires SSL; keep PG_SSL=true.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require
PG_SSL=true

# JWT
# Example formats: 900, 900s, 15m, 7d
JWT_SECRET=change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m

# Password reset links
APP_BASE_URL=http://localhost:5173

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=uploads
